# AI Feeds Configuration
# Copy this file to config.yaml and customize for your setup.

# Feed sources
sources:
  arxiv:
    enabled: true
    categories:
      - cs.AI
      - cs.CL
      - cs.LG
      - stat.ML
    max_results: 150
    delay_seconds: 3.0
    days_back: 2
    timeout_seconds: 30
    retries: 3

  huggingface:
    enabled: true
    limit: 30
    days_back: 2
    timeout_seconds: 30
    retries: 3
    delay_seconds: 1.0

  hackernews:
    enabled: true
    queries:
      - "AI"
      - "LLM"
      - "machine learning"
    max_stories: 30
    timeout_seconds: 30
    retries: 3

  reddit:
    enabled: true
    subreddits:
      - MachineLearning
      - LocalLLaMA
      - artificial
    sort: hot
    limit: 25
    timeout_seconds: 30
    retries: 3
    delay_seconds: 1.0

  github_trending:
    enabled: true
    languages:
      - python
      - typescript
    since: daily
    max_results: 30
    timeout_seconds: 30
    retries: 3
    delay_seconds: 2.0

  producthunt:
    enabled: false  # Requires Chrome with CDP on port 9222
    topics:
      - artificial-intelligence
    timeout_seconds: 15
    retries: 1
    delay_seconds: 2.0
    days: 1
    cdp_endpoint: http://localhost:9222

  devto:
    enabled: true
    tag: ai
    top: 7
    limit: 30
    timeout_seconds: 30
    retries: 3
    delay_seconds: 1.0

# Processing
processor:
  llm:
    provider: claude  # claude, openai, or ollama
    model: claude-sonnet-4-20250514
    batch_size: 10
  relevance_threshold: 7  # Only surface papers scoring 7+

# Database
database:
  path: db/ai-feeds.sqlite

# Telegram notifications
telegram:
  enabled: false
  bot_token_cmd: "pass show telegram/agent-bot-token"  # command to retrieve token
  chat_id: "YOUR_CHAT_ID"
  notify_on: high_scoring  # "always" or "high_scoring" (only when score 8+ papers exist)

# Static site
site:
  enabled: true
  domain: signals.yourdomain.com  # Your custom domain
  vault_path: ~/vault/inbox/signals  # Where to save notes via "Save to Vault" button
  title: AI Signals
  description: "Curated AI industry intelligence — papers, tools, and insights worth your time."

# Output
output:
  vault_path: ~/your-vault-path/signals  # Set to your Obsidian vault signals directory
  format: obsidian

# Learning plan integration
learning_plan:
  interests:
    - context engineering
    - agent architectures
    - RAG
    - fine-tuning
    - production AI
    - LLM integration
    - browser automation
