{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["collectors/**/*.ts", "processor/**/*.ts", "db/**/*.ts", "sources/**/*.ts", "processors/**/*.ts", "pipelines/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
